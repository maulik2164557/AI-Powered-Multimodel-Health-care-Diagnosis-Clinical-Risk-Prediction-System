{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="p-4 bg-white rounded-4 border shadow-sm">
            <div class="text-center mb-3">
                <i class="fas fa-user-plus fa-2x text-primary mb-2"></i>
                <h2 class="fw-bold mb-0">User Registration</h2>
                <p class="text-muted mb-0">Create your account to continue.</p>
            </div>

            <form method="POST">
                {% csrf_token %}

                <div class="row g-3">
                    <div class="col-md-6">{{ form.username.label_tag }} {{ form.username }}</div>
                    <div class="col-md-6">{{ form.email.label_tag }} {{ form.email }}</div>
                    <div class="col-md-6">{{ form.full_name.label_tag }} {{ form.full_name }}</div>
                    <div class="col-md-6">{{ form.date_of_birth.label_tag }} {{ form.date_of_birth }}</div>
                    <div class="col-md-6">{{ form.gender.label_tag }} {{ form.gender }}</div>
                    <div class="col-md-6">{{ form.phone_number.label_tag }} {{ form.phone_number }}</div>
                    <div class="col-md-12">{{ form.address.label_tag }} {{ form.address }}</div>
                    <div class="col-md-6">{{ form.role.label_tag }} {{ form.role }}</div>
                </div>

                <div id="doctor-fields" class="mt-3" style="display:none;">
                    <div class="row g-3">
                        <div class="col-md-6">{{ form.specialization.label_tag }} {{ form.specialization }}</div>
                        <div class="col-md-6">{{ form.license_number.label_tag }} {{ form.license_number }}</div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-md-6">{{ form.password1.label_tag }} {{ form.password1 }}</div>
                    <div class="col-md-6">{{ form.password2.label_tag }} {{ form.password2 }}</div>
                </div>

                {% if form.errors %}
                    <div class="alert alert-danger mt-3">{{ form.errors }}</div>
                {% endif %}

                <button class="btn btn-ai w-100 rounded-pill py-2 mt-3" type="submit">Register</button>
            </form>

            <div class="text-center mt-3">
                <small class="text-muted">Already have an account? <a href="{% url 'accounts:login' %}">Login</a></small>
            </div>
        </div>
    </div>
